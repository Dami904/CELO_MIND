# ── ERC-8004 registration (Celo Mainnet) ──────────────────────────────────────
# Required: signer that pays gas and will OWN the agent NFT. Reuses the same var
# the backend already uses for write tools. Fund it with a little CELO for gas.
CELO_PRIVATE_KEY=0x0c6f48e1d9a03525c5d4b86aabf509eccaf8cf2063a44865df988679473064c4

# Optional — RPC (defaults to https://forno.celo.org)
CELO_MAINNET_RPC_URL=https://forno.celo.org

# Optional — agent card overrides (sensible CeloMind defaults are built in)
AGENT_NAME=CeloMind
# AGENT_DESCRIPTION=CeloMind is an AI-powered assistant for the Celo blockchain.

You talk to it in plain English ; ask about your wallet, swap tokens, check if a contract is risky, track whale wallets, or explore DeFi yields and it fetches live on-chain data and responds conversationally.

Under the hood it's an MCP (Model Context Protocol) server with 75+ tools wired to Celo's mainnet, Blockscout, CoinGecko, DefiLlama, and GeckoTerminal. The AI layer routes each message to the right tool, fetches real data, and synthesizes a clean answer , with a confirmation step before anything touches your wallet.
# AGENT_IMAGE=https://raw.githubusercontent.com/Dami904/CELO_MIND/main/frontend/public/logo-dark.png
MCP_ENDPOINT=https://celo-mind-nmk2.onrender.com/mcp
# WEB_ENDPOINT=https://celomind.vercel.app/        # optional public dashboard URL

# Optional — use a hosted card (https/ipfs) instead of the on-chain data: URI
# AGENT_URI=https://.../agent-card.json

# Flags
# DRY_RUN=1     # build + print the card, send no transaction
# FINALIZE=1    # after register, add a 2nd tx embedding the on-chain agentId

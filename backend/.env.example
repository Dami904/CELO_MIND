PORT=3001
HOST=0.0.0.0

# Mainnet-only. Keep this as "celo".
CELO_NETWORK=celo

# Required for the global dashboard metrics (Upstash Redis REST).
# Without these the app still runs — metrics just read as zeros.
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# AI provider. Set at least one key; Gemini is the default provider.
AI_PROVIDER=
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Database. Local libsql file by default (ephemeral on Render's free tier).
# For durable logs + a durable metrics mirror that survives Render restarts/Redis
# outages, point DATABASE_URL at a Turso libsql:// URL and set DATABASE_AUTH_TOKEN.
DATABASE_URL=./celomind.db
DATABASE_AUTH_TOKEN=

# Optional data/API integrations.
BLOCKSCOUT_API_KEY=
DUNE_API_KEY=
COINGECKO_API_KEY=
CELO_RPC_URL=
CELO_MAINNET_RPC_URL=
MARKET_NETWORK=

PORT=3001
HOST=0.0.0.0

# Mainnet-only. Keep this as "celo".
CELO_NETWORK=celo

# Required for the global dashboard metrics (Upstash Redis REST).
# Without these the app still runs — metrics just read as zeros.
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# AI providers. Active providers: Groq, Cohere, OpenRouter, Gemini.
# Selection is TASK-BASED (see apps/api/src/ai/providers.ts): each intent is
# routed to the best-fit provider, with automatic failover to the others.
# Set AI_PROVIDER only if you want to FORCE one provider for every request.
AI_PROVIDER=

# Groq — fast structured data + reasoning (default workhorse).
GROQ_API_KEY=
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_SMART=llama-3.3-70b-versatile

# Cohere — educational / docs grounding (RAG-optimized).
COHERE_API_KEY=
COHERE_MODEL=command-a-03-2025

# OpenRouter — meta-router, used as a failover provider.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# Gemini — high daily quota, used as the catch-all default + failover.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite


# Database. Local libsql file by default (ephemeral on Render's free tier).
# For durable logs + a durable metrics mirror that survives Render restarts/Redis
# outages, point DATABASE_URL at a Turso libsql:// URL and set DATABASE_AUTH_TOKEN.
DATABASE_URL=./celomind.db
DATABASE_AUTH_TOKEN=

# Optional data/API integrations.
BLOCKSCOUT_API_KEY=
DUNE_API_KEY=
COINGECKO_API_KEY=
CELO_RPC_URL=
CELO_MAINNET_RPC_URL=
MARKET_NETWORK=

{
  "name": "celomind",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "npm run dev -w apps/api",
    "start": "node apps/api/dist/server.js",
    "start:mcp": "node packages/mcp-server/dist/index.js",
    "test": "vitest run",
    "smoke": "node scripts/smoke.mjs",
    "register:8004": "tsx scripts/register-8004.ts",
    "lint": "tsc --noEmit --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@ai-sdk/cohere": "^3.0.36",
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/groq": "^3.0.39",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "ai": "^6.0.197"
  }
}
